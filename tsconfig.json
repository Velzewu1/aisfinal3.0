{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@llm/*": ["llm/*"],
      "@extension/*": ["extension/*"]
    }
  },
  "include": ["extension/**/*.ts", "llm/**/*.ts", "ui/**/*.tsx", "ui/**/*.ts"],
  "exclude": ["node_modules", "extension/dist", "ui/dist"]
}
