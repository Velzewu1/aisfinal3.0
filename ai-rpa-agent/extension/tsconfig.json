{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["chrome"],
    "baseUrl": ".",
    "paths": {
      "@ai-rpa/schemas": ["../packages/schemas/src/index.ts"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": [
    "background/**/*.ts",
    "content/**/*.ts",
    "sidepanel/**/*.ts",
    "voice/**/*.ts",
    "llm/**/*.ts",
    "controller/**/*.ts",
    "shared/**/*.ts"
  ]
}
